{
  "namespace": "hud",
  "hud_title_text": {
    "type": "stack_panel",
    "size": [
      "100%cm",
      "100%c"
    ],
    "anchor_from": "right_middle",
    "anchor_to": "right_middle",
    "offset": [
      -1,
      0
    ],
    "alpha": 0.8,
    "controls": [
      {
        "sidebar": {
          "type": "panel",
          "size": [
            "100%c",
            "90%c"
          ],
          "offset": [
            0,
            0
          ],
          "controls": [
            {
              "title_background": {
                "type": "image",
                "alpha": 1,
                "size": [
                  "100%cm",
                  "100%c+3px"
                ],
                "texture": "textures/board/background",
                "controls": [
                  {
                    "scoreboard_logo": {
                      "type": "image",
                      "size": [
                        102,
                        44
                      ],
                      "offset": [
                        0,
                        2
                      ],
                      "anchor_from": "top_middle",
                      "anchor_to": "top_middle",
                      "texture": "textures/form/title"
                    }
                  },
                  {
                    "text": {
                      "type": "panel",
                      "anchor_from": "bottom_left",
                      "anchor_to": "bottom_left",
                      "offset": [
                        8,
                        -3
                      ],
                      "size": [
                        "100%c",
                        "100%cm"
                      ],
                      "controls": [
                        {
                          "title": {
                            "type": "label",
                            "text": "$title_text",
                            "shadow": true,
                            "anchor_from": "left_middle",
                            "anchor_to": "left_middle",
                            "text_alignment": "left",
                            "layer": 2,
                            "localize": false,
                            "font_scale_factor": 1
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "chat_grid_item/chat_background": {
    "bindings": [
      {
        "binding_name": "#chat_text",
        "binding_name_override": "#text",
        "binding_type": "collection",
        "binding_collection_name": "chat_text_grid",
        "binding_condition": "once"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not(#text = 'clearchat-nperma'))",
        "target_property_name": "#visible"
      }
    ]
  },
  "anim_title_text_alpha_out": {
    "anim_type": "alpha",
    "easing": "in_expo",
    "duration": 1,
    "from": 1,
    "to": 0,
    "destroy_at_end": "hud_title_text"
  },
  "anim_title_text_background_alpha_out": {
    "anim_type": "alpha",
    "easing": "in_expo",
    "duration": 1,
    "from": 0.6,
    "to": 0,
    "destroy_at_end": "hud_title_text"
  },
  "anim_chat_txt_alpha": {
    "anim_type": "alpha",
    "easing": "in_quart",
    "duration": 1,
    "from": 1,
    "to": 0
  },
  "anim_chat_txt_wait": {
    "anim_type": "wait",
    "duration": "$chat_item_lifetime",
    "next": "@hud.anim_chat_txt_alpha"
  },
  "anim_chat_bg_alpha": {
    "anim_type": "alpha",
    "easing": "in_quart",
    "destroy_at_end": "chat_grid_item",
    "duration": 1,
    "from": 0.7,
    "to": 0
  },
  "anim_chat_bg_wait": {
    "anim_type": "wait",
    "duration": "$chat_item_lifetime",
    "next": "@hud.anim_chat_bg_alpha"
  },
  "anim_chat_off": {
    "anim_type": "offset",
    "easing": "out_sine",
    "duration": 0.5,
    "from": [
      -100,
      0
    ],
    "to": [
      0,
      0
    ],
    "next": "@hud.anim_chat_wait_off"
  },
  "anim_chat_wait_off": {
    "anim_type": "wait",
    "duration": 5.5,
    "next": "@hud.anim_chat_out_off2"
  },
  "anim_chat_out_off1": {
    "anim_type": "offset",
    "easing": "in_sine",
    "duration": 0.5,
    "from": [
      -100,
      0
    ],
    "to": [
      -1400,
      0
    ]
  },
  "anim_chat_out_off2": {
    "anim_type": "offset",
    "easing": "in_sine",
    "duration": 0.5,
    "from": [
      0,
      0
    ],
    "to": [
      -100,
      0
    ],
    "next": "@hud.anim_chat_out_off1"
  },
  "chat_label": {
    "type": "label",
    "layer": 31,
    "text": "#text",
    "size": [
      "100%",
      "default"
    ],
    "shadow": true,
    "localize": false,
    "color": "$chat_text_color",
    "font_type": "$chat_font_type",
    "font_scale_factor": "$chat_font_scale_factor",
    "line_padding": "$chat_line_spacing",
    "anims": [
      "@hud.anim_chat_txt_wait"
    ],
    "bindings": [
      {
        "binding_name": "#chat_text",
        "binding_name_override": "#text",
        "binding_type": "collection",
        "binding_collection_name": "chat_text_grid",
        "binding_condition": "once"
      }
    ]
  },
  "chat_grid_item": {
    "type": "panel",
    "layer": 1,
    "size": [
      "100%-2px",
      "100%c"
    ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [0, 0],
    "anims": [
      "@hud.anim_chat_off"
    ],
    "controls": [
      {
        "chat_background": {
          "type": "image",
          "texture": "textures/ui/Black",
          "alpha": 0.7,
          "size": [
            "100%",
            "100%c"
          ],
          "offset": [0, 0],
          "anims": [
            "@hud.anim_chat_bg_wait"
          ],
          "controls": [
            {
              "chat_text@chat_label": {
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [
                  2,
                  0
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "chat_panel": {
    "type": "panel",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "size": [
      "100%",
      "100%c"
    ],
    "max_size": [
      "100%",
      "50%"
    ],
    "controls": [
      {
        "stack_panel": {
          "type": "stack_panel",
          "anchor_from": "bottom_left",
          "anchor_to": "bottom_left",
          "factory": {
            "name": "chat_item_factory",
            "max_children_size": 50,
            "control_ids": {
              "chat_item": "chat_item@hud.chat_grid_item"
            }
          }
        }
      }
    ]
  }
}