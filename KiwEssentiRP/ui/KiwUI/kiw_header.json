    "controls": [
      {"label": {"type": "label", "text": "#title_text", "color": [1, 1, 1], "font_scale_factor": 1.2, "anchor_from": "top_middle", "anchor_to": "top_middle", "bindings": [{"binding_name": "#title_text"}, {"binding_type": "view", "source_property_name": "(not ((#title_text = 'Member Menu') or (#title_text = 'KiwEss-Grid') or (#title_text = 'Member Menu Grid') or (#title_text = 'Menu Grid Member')))", "target_property_name": "#visible"}]}}
