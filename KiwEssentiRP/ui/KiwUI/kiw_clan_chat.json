{
  "namespace": "kiw_clan_chat",
  "chat_panel": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "controls": [
      {
        "chat_container": {
          "type": "panel",
          "size": [
            420,
            200
          ],
          "anchor_from": "center",
          "anchor_to": "center",
          "offset": [
            0,
            0
          ],
          "layer": 1,
          "controls": [
            {
              "status_bar": {
                "type": "panel",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [
                  9,
                  -15
                ],
                "size": [
                  "100% - 80px",
                  25
                ],
                "layer": 15,
                "controls": [
                  {
                    "bg@kiw_common.bg_dialog": {}
                  },
                  {
                    "title_label": {
                      "type": "label",
                      "text": "#title_text",
                      "color": [
                        1,
                        1,
                        1
                      ],
                      "font_scale_factor": 1.1,
                      "anchor_from": "left_middle",
                      "anchor_to": "left_middle",
                      "offset": [
                        8,
                        0
                      ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_name": "#title_text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "close_button": {
                "type": "button",
                "anchor_from": "top_right",
                "anchor_to": "top_right",
                "offset": [
                  -9,
                  -15
                ],
                "size": [
                  60,
                  24
                ],
                "layer": 25,
                "default_control": "default",
                "hover_control": "hover",
                "pressed_control": "pressed",
                "button_mappings": [
                  {
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.menu_exit",
                    "mapping_type": "pressed"
                  },
                  {
                    "from_button_id": "button.menu_cancel",
                    "to_button_id": "button.menu_exit",
                    "mapping_type": "global"
                  }
                ],
                "controls": [
                  {
                    "default@kiw_clan_chat.close_btn_base": {
                      "$bg_color": [
                        0.8,
                        0,
                        0
                      ]
                    }
                  },
                  {
                    "hover@kiw_clan_chat.close_btn_base": {
                      "$bg_color": [
                        1,
                        0.2,
                        0.2
                      ]
                    }
                  },
                  {
                    "pressed@kiw_clan_chat.close_btn_base": {
                      "$bg_color": [
                        0.6,
                        0,
                        0
                      ],
                      "$text_color": [
                        0.8,
                        0.8,
                        0.8
                      ]
                    }
                  }
                ]
              }
            },
            {
              "main_content": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [
                  "100% - 18px",
                  "85%"
                ],
                "anchor_from": "center",
                "anchor_to": "center",
                "offset": [
                  0,
                  0
                ],
                "layer": 1,
                "controls": [
                  {
                    "left_sidebar": {
                      "type": "panel",
                      "size": [
                        110,
                        "100%"
                      ],
                      "controls": [
                        {
                          "sidebar_bg@kiw_common.bg_dialog": {
                            "layer": 0
                          }
                        },
                        {
                          "sidebar_content": {
                            "type": "panel",
                            "size": [
                              "100% - 8px",
                              "100% - 8px"
                            ],
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "layer": 2,
                            "controls": [
                              {
                                "member_list_scroller@common.scrolling_panel": {
                                  "$show_background": false,
                                  "$scrolling_content": "kiw_clan_chat.chat_buttons_stack",
                                  "size": ["100%", "100%"],
                                  "$scroll_size": [0, 0],
                                  "$scrolling_pane_size": ["100%", "100%"],
                                  "clips_children": true
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "right_chat_area": {
                      "type": "panel",
                      "size": [
                        "fill",
                        "100%"
                      ],
                      "controls": [
                        {
                          "chat_bg@kiw_common.bg_dialog": {
                            "layer": 0
                          }
                        },
                        {
                          "chat_content": {
                            "type": "panel",
                            "size": [
                              "100% - 6px",
                              "100% - 6px"
                            ],
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "layer": 2,
                            "controls": [
                              {
                                "chat_scroll@common.scrolling_panel": {
                                  "$show_background": false,
                                  "$scrolling_content": "kiw_clan_chat.sidebar_body",
                                  "size": [
                                    "100%",
                                    "100%"
                                  ],
                                  "$scroll_size": [
                                    0,
                                    0
                                  ],
                                  "$scrolling_pane_size": [
                                    "100% - 4px",
                                    "100%"
                                  ],
                                  "clips_children": true
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "sidebar_body": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "body_label": {
          "type": "label",
          "text": "#form_text",
          "color": [
            1,
            1,
            1
          ],
          "font_scale_factor": 0.9,
          "size": [
            "100%",
            "default"
          ],
          "text_alignment": "left",
          "shadow": true,
          "bindings": [
            {
              "binding_name": "#form_text"
            }
          ]
        }
      },
      {
        "pad": {
          "type": "panel",
          "size": [
            "100%",
            4
          ]
        }
      }
    ]
  },
  "sidebar_btn_send": {
    "type": "button",
    "size": ["100%", 22],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [{"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}],
    "controls": [
      {"default@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.2, 0.8, 0.2], "$btn_text": "§a✉ Send"}},
      {"hover@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.3, 0.9, 0.3], "$btn_text": "§a✉ Send"}},
      {"pressed@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.1, 0.6, 0.1], "$btn_text": "§a✉ Send"}}
    ]
  },
  "sidebar_btn_refresh": {
    "type": "button",
    "size": ["100%", 22],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [{"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}],
    "controls": [
      {"default@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.2, 0.5, 0.8], "$btn_text": "§b⟳ Refresh"}},
      {"hover@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.3, 0.6, 0.9], "$btn_text": "§b⟳ Refresh"}},
      {"pressed@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.1, 0.4, 0.7], "$btn_text": "§b⟳ Refresh"}}
    ]
  },
  "sidebar_btn_clear": {
    "type": "button",
    "size": ["100%", 22],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [{"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}],
    "controls": [
      {"default@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.8, 0.2, 0.2], "$btn_text": "§c✕ Clear"}},
      {"hover@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.9, 0.3, 0.3], "$btn_text": "§c✕ Clear"}},
      {"pressed@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.6, 0.1, 0.1], "$btn_text": "§c✕ Clear"}}
    ]
  },
  "sidebar_btn_scroll_up": {
    "type": "button",
    "size": ["100%", 18],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [{"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}],
    "controls": [
      {"default@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.5, 0.5, 0.5], "$btn_text": "§7▲ Up"}},
      {"hover@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.6, 0.6, 0.6], "$btn_text": "§7▲ Up"}},
      {"pressed@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.4, 0.4, 0.4], "$btn_text": "§7▲ Up"}}
    ]
  },
  "sidebar_btn_scroll_down": {
    "type": "button",
    "size": ["100%", 18],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [{"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}],
    "controls": [
      {"default@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.5, 0.5, 0.5], "$btn_text": "§7▼ Down"}},
      {"hover@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.6, 0.6, 0.6], "$btn_text": "§7▼ Down"}},
      {"pressed@kiw_clan_chat.sidebar_btn_panel": {"$btn_color": [0.4, 0.4, 0.4], "$btn_text": "§7▼ Down"}}
    ]
  },
  "sidebar_btn_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "$btn_color|default": [1, 1, 1],
    "$btn_text|default": "Button",
    "controls": [
      {
        "bg": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": "$btn_color",
          "size": ["100%", "100%"]
        }
      },
      {
        "text": {
          "type": "label",
          "text": "$btn_text",
          "color": [1, 1, 1],
          "anchor_from": "center",
          "anchor_to": "center",
          "font_scale_factor": 0.85
        }
      }
    ]
  },
  "chat_buttons_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "top_pad": {
          "type": "panel",
          "size": [
            "100%",
            2
          ]
        }
      },
      {
        "buttons_list": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": [
            "100%",
            "100%c"
          ],
          "collection_name": "form_buttons",
          "factory": {
            "name": "form_buttons",
            "control_ids": {
              "button": "@kiw_clan_chat.chat_item"
            }
          },
          "bindings": [
            {
              "binding_name": "#form_button_contents",
              "binding_name_override": "#collection_length"
            }
          ]
        }
      },
      {
        "bottom_pad": {
          "type": "panel",
          "size": [
            "100%",
            4
          ]
        }
      }
    ]
  },
  "chat_item": {
    "type": "button",
    "size": [
      "100%",
      20
    ],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.form_button_click",
        "mapping_type": "pressed"
      }
    ],
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "default@kiw_clan_chat.chat_item_panel": {
          "$item_alpha": 0.0
        }
      },
      {
        "hover@kiw_clan_chat.chat_item_panel": {
          "$item_alpha": 0.3
        }
      },
      {
        "pressed@kiw_clan_chat.chat_item_panel": {
          "$item_alpha": 0.5
        }
      }
    ]
  },
  "chat_item_panel": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "$item_alpha|default": 0.0,
    "controls": [
      {
        "hover_bg": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": [
            0.4,
            0.4,
            0.5
          ],
          "alpha": "$item_alpha",
          "size": [
            "100%",
            "100%"
          ]
        }
      },
      {
        "item_text": {
          "type": "label",
          "text": "#form_button_text",
          "color": [
            1,
            1,
            1
          ],
          "font_scale_factor": 1.0,
          "size": [
            "100% - 8px",
            "default"
          ],
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "offset": [
            4,
            0
          ],
          "shadow": true,
          "bindings": [
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      }
    ]
  },
  "close_btn_base": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "$bg_color|default": [
      1,
      1,
      1
    ],
    "$text_color|default": [
      1,
      1,
      1
    ],
    "controls": [
      {
        "bg": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": "$bg_color",
          "alpha": 1,
          "size": [
            "100%",
            "100%"
          ]
        }
      },
      {
        "text": {
          "type": "label",
          "text": "CLOSE",
          "color": "$text_color",
          "anchor_from": "center",
          "anchor_to": "center"
        }
      }
    ]
  }
}