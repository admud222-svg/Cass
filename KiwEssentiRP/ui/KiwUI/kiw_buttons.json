{
    "namespace": "kiw_buttons",
    "close_button": {
        "type": "button",
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "offset": [-9, -15],
        "size": [60, 24],
        "layer": 25,
        "focus_enabled": true,
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "locked_control": "hover",
        "button_mappings": [
            {"from_button_id": "button.menu_select", "to_button_id": "button.menu_exit", "mapping_type": "pressed"}
        ],
        "controls": [
            {"default@kiw_buttons.close_button_default": {}},
            {"hover@kiw_buttons.close_button_hover": {}},
            {"pressed@kiw_buttons.close_button_pressed": {}}
        ]
    },
    "close_button_default": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.8, 0, 0], "size": ["100%", "100%"]}},
            {"text": {"type": "label", "text": "CLOSE", "layer": 5, "color": [1, 1, 1], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "close_button_hover": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [1, 0.2, 0.2], "size": ["100%", "100%"]}},
            {"text": {"type": "label", "text": "CLOSE", "layer": 5, "color": [1, 1, 1], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "close_button_pressed": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.6, 0, 0], "size": ["100%", "100%"]}},
            {"text": {"type": "label", "text": "CLOSE", "layer": 5, "color": [0.8, 0.8, 0.8], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "header_toggle_area": {
        "type": "stack_panel",
        "orientation": "horizontal",
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "offset": [-75, -15],
        "size": [30, 24],
        "layer": 25,
        "collection_name": "form_buttons",
        "bindings": [{"binding_name": "#form_button_contents", "binding_name_override": "#collection_length"}],
        "factory": {
            "name": "toggle_buttons",
            "control_ids": {"button": "kiw_buttons.toggle_button_filtered"}
        }
    },
    "toggle_button_filtered": {
        "type": "panel",
        "size": ["100%", "100%"],
        "bindings": [
            {"binding_type": "collection_details", "binding_collection_name": "form_buttons"},
            {"binding_name": "#form_button_text", "binding_type": "collection", "binding_collection_name": "form_buttons"},
            {"binding_type": "view", "source_property_name": "((#form_button_text = '§a§lList Mode') or (#form_button_text = '§a§lGrid Mode'))", "target_property_name": "#visible"}
        ],
        "controls": [{"button@kiw_buttons.toggle_button_visual": {}}]
    },
    "toggle_button_visual": {
        "type": "button",
        "size": [28, 24],
        "focus_enabled": true,
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "locked_control": "hover",
        "button_mappings": [
            {"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"},
            {"from_button_id": "button.menu_ok", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}
        ],
        "bindings": [{"binding_type": "collection_details", "binding_collection_name": "form_buttons"}],
        "controls": [
            {"default@kiw_buttons.toggle_btn_default": {}},
            {"hover@kiw_buttons.toggle_btn_hover": {}},
            {"pressed@kiw_buttons.toggle_btn_pressed": {}}
        ]
    },
    "toggle_btn_default": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.2, 0.7, 0.2], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "▦", "layer": 5, "font_scale_factor": 1.2, "color": [1, 1, 1], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_btn_hover": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.3, 0.9, 0.3], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "▦", "layer": 5, "font_scale_factor": 1.2, "color": [1, 1, 1], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_btn_pressed": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.1, 0.5, 0.1], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "▦", "layer": 5, "font_scale_factor": 1.2, "color": [0.8, 0.8, 0.8], "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_view_list": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.2, 0.4, 0.6], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "☰", "color": [1, 1, 1], "font_scale_factor": 1.2, "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_view_list_hover": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.3, 0.5, 0.7], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "☰", "color": [1, 1, 1], "font_scale_factor": 1.2, "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_view_grid": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.4, 0.6, 0.2], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "▦", "color": [1, 1, 1], "font_scale_factor": 1.2, "anchor_from": "center", "anchor_to": "center"}}
        ]
    },
    "toggle_view_grid_hover": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {"bg": {"type": "image", "texture": "textures/ui/White", "color": [0.5, 0.7, 0.3], "size": ["100%", "100%"]}},
            {"icon": {"type": "label", "text": "▦", "color": [1, 1, 1], "font_scale_factor": 1.2, "anchor_from": "center", "anchor_to": "center"}}
        ]
    }
}