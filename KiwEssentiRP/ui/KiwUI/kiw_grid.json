{
  "namespace": "kiw_grid",
  "grid_content_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [{"grid_scroller@kiw_grid.grid_scroller": {}}]
  },
  "grid_scroller@common.scrolling_panel": {
    "layer": 5,
    "$show_background": false,
    "$scrolling_content": "kiw_grid.grid_wrap_panel",
    "$scroll_size": [0, 0],
    "$scrolling_pane_size": ["100%", "100%"]
  },
  "grid_wrap_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"],
    "controls": [
      {"grid@kiw_grid.grid_layout": {}},
      {"bottom_padding": {"type": "panel", "size": ["100%", 10]}}
    ]
  },
  "grid_layout": {
    "type": "grid",
    "grid_dimensions": [4, 9],
    "grid_item_template": "kiw_grid.grid_button_wrapper",
    "collection_name": "form_buttons",
    "size": ["100%", "100%c"],
    "bindings": [
      {
        "binding_name": "#form_button_contents",
        "binding_name_override": "#collection_length"
      }
    ]
  },
  "grid_button_wrapper": {
    "type": "panel",
    "size": ["25%", 60],
    "bindings": [
      {"binding_type": "collection_details", "binding_collection_name": "form_buttons"},
      {
        "binding_name": "#form_button_text",
        "binding_name_override": "#button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#form_button_text = '') or (#form_button_text = '§a§lList Mode') or (#form_button_text = '§a§lGrid Mode') or (#form_button_text = '§a§lMode List') or (#form_button_text = '§a§lMode Grid') or (#form_button_text = 'Back') or (#form_button_text = 'back') or (#form_button_text = '← Back') or (#form_button_text = 'Balik') or (#form_button_text = 'Tutup Menu')))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [{"button@kiw_grid.grid_button": {}}]
  },
  "grid_button": {
    "type": "button",
    "size": ["95%", 55],
    "anchor_from": "center",
    "anchor_to": "center",
    "focus_enabled": true,
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "locked_control": "hover",
    "button_mappings": [
      {"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"},
      {"from_button_id": "button.menu_ok", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}
    ],
    "bindings": [{"binding_type": "collection_details", "binding_collection_name": "form_buttons"}],
    "controls": [
      {"default@kiw_grid.grid_button_state": {"$bg_texture": "textures/button/default"}},
      {"hover@kiw_grid.grid_button_state": {"$bg_texture": "textures/button/hover"}},
      {"pressed@kiw_grid.grid_button_state": {"$bg_texture": "textures/button/hover"}}
    ]
  },
  "grid_button_state": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "bg": {
          "type": "image",
          "texture": "$bg_texture",
          "nineslice_size": 6,
          "size": ["100%", "100%"]
        }
      },
      {
        "icon_container": {
          "type": "panel",
          "size": ["100%", 28],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [0, 4],
          "controls": [
            {
              "icon": {
                "type": "image",
                "layer": 5,
                "size": [24, 24],
                "anchor_from": "center",
                "anchor_to": "center",
                "bindings": [
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "label": {
          "type": "label",
          "layer": 5,
          "size": ["90%", "default"],
          "anchor_from": "bottom_middle",
          "anchor_to": "bottom_middle",
          "offset": [0, -6],
          "text": "#form_button_text",
          "color": [1, 1, 1],
          "shadow": true,
          "font_scale_factor": 0.7,
          "text_alignment": "center",
          "bindings": [
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      }
    ]
  }
}