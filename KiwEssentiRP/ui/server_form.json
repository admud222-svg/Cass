{
  "namespace": "server_form",
  "third_party_server_screen@common.base_screen": {
    "$screen_content": "server_form.main_screen_content",
    "render_game_behind": true,
    "absorbs_input": true,
    "button_mappings": [
      {
        "from_button_id": "button.menu_cancel",
        "to_button_id": "button.menu_exit",
        "mapping_type": "global"
      }
    ]
  },
  "main_screen_content": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "server_form_factory": {
          "type": "factory",
          "control_ids": {
            "long_form": "@server_form.long_form",
            "custom_form": "@server_form.custom_form"
          }
        }
      }
    ]
  },
  "long_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "clan_chat_stack": {
          "type": "panel",
          "size": ["100%", "100%"],
          "layer": 5,
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(not ((#title_text - 'Clan Chat') = #title_text))",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "clan_chat_ui@kiw_clan_chat.chat_panel": {
                "anchor_from": "center",
                "anchor_to": "center"
              }
            }
          ]
        }
      },
      {
        "main_stack": {
          "type": "stack_panel",
          "size": [350, "100%c"],
          "anchor_from": "center",
          "anchor_to": "center",
          "offset": [0, 0],
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - 'Clan Chat') = #title_text)",
              "target_property_name": "#visible"
            }
          ],
          "controls": [
            {
              "admin_panel@kiw_main.admin_panel": {
                "anchor_from": "center",
                "anchor_to": "center"
              }
            },
            {
              "padding": {
                "type": "panel",
                "size": [350, 8]
              }
            }
          ]
        }
      }
    ]
  },
  "dynamic_button": {
    "type": "panel",
    "size": ["96%", 34],
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {"binding_type": "collection_details", "binding_collection_name": "form_buttons"},
      {"binding_name": "#form_button_text", "binding_name_override": "#button_text", "binding_type": "collection", "binding_collection_name": "form_buttons"},
      {"binding_type": "view", "source_control_name": "search_items_control", "source_property_name": "#item_name", "target_property_name": "#search_control"},
      {"binding_type": "view", "source_property_name": "(#search_control = '' or (not ((#button_text - #search_control) = #button_text)))", "target_property_name": "#visible"}
    ],
    "controls": [{
      "button": {
        "type": "button",
        "size": ["100%", 30],
        "anchor_from": "center",
        "anchor_to": "center",
        "focus_enabled": true,
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "locked_control": "hover",
        "button_mappings": [
          {"from_button_id": "button.menu_select", "to_button_id": "button.form_button_click", "mapping_type": "pressed"},
          {"from_button_id": "button.menu_ok", "to_button_id": "button.form_button_click", "mapping_type": "pressed"}
        ],
        "bindings": [{"binding_type": "collection_details", "binding_collection_name": "form_buttons"}],
        "controls": [
          {"default@kiw_content.content_button_state": {"$bg_texture": "textures/button/default"}},
          {"hover@kiw_content.content_button_state": {"$bg_texture": "textures/button/hover"}},
          {"pressed@kiw_content.content_button_state": {"$bg_texture": "textures/button/hover"}}
        ]
      }
    }]
  },
  "dynamic_label@settings_common.option_group_spaced_label": {
    "$text": "#form_button_text",
    "$text_bindings": [
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ]
  },
  "dynamic_header@settings_common.option_group_spaced_header": {
    "$text": "#form_button_text",
    "$text_bindings": [
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ]
  },
  "custom_form@kiw_modal.main_panel": {},
  "custom_form_panel@common.scrolling_panel": {
    "anchor_to": "top_left",
    "anchor_from": "top_left",
    "$show_background": false,
    "size": ["100%", "100%"],
    "$scrolling_content": "server_form.custom_form_scrolling_content",
    "$scroll_size": [5, "100% - 4px"],
    "$scrolling_pane_size": ["100% - 4px", "100% - 2px"],
    "$scrolling_pane_offset": [2, 0],
    "$scroll_bar_right_padding_size": [0, 0]
  },
  "generated_contents": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"],
    "factory": {
      "name": "form_buttons",
      "control_ids": {
        "button": "server_form.dynamic_button",
        "label": "server_form.dynamic_label",
        "header": "server_form.dynamic_header"
      }
    }
  },
  "custom_form_scrolling_content": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"],
    "controls": [
      {
        "header_padding": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "generated_contents@server_form.generated_contents": {}
      }
    ]
  }
}
