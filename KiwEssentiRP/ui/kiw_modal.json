{
  "namespace": "kiw_modal",
  "main_panel": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "controls": [
      {
        "bg_overlay": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": [
            0,
            0,
            0
          ],
          "alpha": 0.5,
          "size": [
            "100%",
            "100%"
          ],
          "layer": 0
        }
      },
      {
        "modal_container": {
          "type": "panel",
          "size": [
            350,
            200
          ],
          "anchor_from": "center",
          "anchor_to": "center",
          "layer": 1,
          "controls": [
            {
              "status_bar": {
                "type": "panel",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [
                  9,
                  -15
                ],
                "size": [
                  "100% - 80px",
                  25
                ],
                "layer": 15,
                "controls": [
                  {
                    "bg@kiw_common.bg_dialog": {}
                  },
                  {
                    "title_label": {
                      "type": "label",
                      "text": "#title_text",
                      "color": [
                        1,
                        1,
                        1
                      ],
                      "anchor_from": "left_middle",
                      "anchor_to": "left_middle",
                      "offset": [
                        8,
                        0
                      ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_name": "#title_text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "close_button": {
                "type": "button",
                "anchor_from": "top_right",
                "anchor_to": "top_right",
                "offset": [
                  -9,
                  -15
                ],
                "size": [
                  60,
                  24
                ],
                "layer": 25,
                "default_control": "default",
                "hover_control": "hover",
                "pressed_control": "pressed",
                "button_mappings": [
                  {
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.menu_exit",
                    "mapping_type": "pressed"
                  },
                  {
                    "from_button_id": "button.menu_cancel",
                    "to_button_id": "button.menu_exit",
                    "mapping_type": "global"
                  }
                ],
                "controls": [
                  {
                    "default@kiw_modal.close_button_base": {
                      "$bg_color": [
                        0.8,
                        0,
                        0
                      ]
                    }
                  },
                  {
                    "hover@kiw_modal.close_button_base": {
                      "$bg_color": [
                        1,
                        0.2,
                        0.2
                      ]
                    }
                  },
                  {
                    "pressed@kiw_modal.close_button_base": {
                      "$bg_color": [
                        0.6,
                        0,
                        0
                      ],
                      "$text_color": [
                        0.8,
                        0.8,
                        0.8
                      ]
                    }
                  }
                ]
              }
            },
            {
              "main_content_area": {
                "type": "panel",
                "size": [
                  "100% - 18px",
                  "100% - 58px"
                ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [
                  0,
                  12
                ],
                "layer": 1,
                "clips_children": false,
                "controls": [
                  {
                    "main_bg@kiw_common.bg_dialog": {
                      "layer": 0
                    }
                  },
                  {
                    "form_content_panel": {
                      "type": "panel",
                      "size": [
                        "100%",
                        "100%"
                      ],
                      "anchor_from": "center",
                      "anchor_to": "center",
                      "layer": 2,
                      "clips_children": true,
                      "controls": [
                        {
                          "scrolling_panel@common.scrolling_panel": {
                            "$show_background": false,
                            "$scrolling_content": "kiw_modal.scrolling_content",
                            "size": [
                              "100%",
                              "100%"
                            ],
                            "$scroll_size": [
                              0,
                              0
                            ],
                            "$scrolling_pane_size": [
                              "100% - 16px",
                              "100%"
                            ],
                            "$scrolling_pane_offset": [
                              8,
                              8
                            ],
                            "clips_children": true
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "submit_section": {
                "type": "panel",
                "size": [
                  "100% - 18px",
                  32
                ],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [
                  0,
                  -6
                ],
                "layer": 3,
                "controls": [
                  {
                    "submit_bg@kiw_common.bg_dialog": {
                      "layer": 0
                    }
                  },
                  {
                    "submit_button@common_buttons.light_text_button": {
                      "$pressed_button_name": "button.submit_custom_form",
                      "anchor_from": "center",
                      "anchor_to": "center",
                      "size": [
                        "100% - 16px",
                        26
                      ],
                      "$button_text": "#submit_text",
                      "$button_text_binding_type": "global",
                      "$button_binding_condition": "always",
                      "layer": 1,
                      "bindings": [
                        {
                          "binding_name": "#submit_button_visible",
                          "binding_name_override": "#visible"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "close_button_base": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "$bg_color|default": [
      1,
      1,
      1
    ],
    "$text_color|default": [
      1,
      1,
      1
    ],
    "controls": [
      {
        "bg": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": "$bg_color",
          "alpha": 1,
          "size": [
            "100%",
            "100%"
          ]
        }
      },
      {
        "text": {
          "type": "label",
          "text": "CLOSE",
          "color": "$text_color",
          "anchor_from": "center",
          "anchor_to": "center"
        }
      }
    ]
  },
  "scrolling_content": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "top_padding": {
          "type": "panel",
          "size": [
            "100%",
            16
          ]
        }
      },
      {
        "generated_form": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": [
            "100%",
            "100%c"
          ],
          "factory": {
            "name": "buttons",
            "control_ids": {
              "label": "@kiw_modal.custom_label",
              "toggle": "@kiw_modal.custom_toggle",
              "slider": "@kiw_modal.custom_slider",
              "step_slider": "@kiw_modal.custom_step_slider",
              "dropdown": "@kiw_modal.custom_dropdown",
              "input": "@kiw_modal.custom_input",
              "header": "@kiw_modal.custom_header"
            }
          },
          "collection_name": "custom_form",
          "bindings": [
            {
              "binding_name": "#custom_form_length",
              "binding_name_override": "#collection_length"
            }
          ]
        }
      },
      {
        "bot_padding": {
          "type": "panel",
          "size": [
            "100%",
            16
          ]
        }
      }
    ]
  },
  "custom_label": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "label_content@server_form.custom_label": {
          "$text_color": [
            0.9,
            0.9,
            0.9
          ],
          "size": [
            "100%",
            "100%c"
          ],
          "$option_tooltip_area": "inside_header_panel"
        }
      },
      {
        "label_spacer": {
          "type": "panel",
          "size": [
            "100%",
            10
          ]
        }
      }
    ]
  },
  "custom_header": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "header_spacer_top": {
          "type": "panel",
          "size": [
            "100%",
            10
          ]
        }
      },
      {
        "header_content@server_form.custom_header": {
          "$text_color": [
            1.0,
            0.8,
            0.0
          ],
          "size": [
            "100%",
            "100%c"
          ],
          "$option_tooltip_area": "inside_header_panel"
        }
      },
      {
        "header_spacer_bot": {
          "type": "panel",
          "size": [
            "100%",
            8
          ]
        }
      }
    ]
  },
  "custom_toggle": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "toggle_top_spacer": {
          "type": "panel",
          "size": [
            "100%",
            4
          ]
        }
      },
      {
        "toggle_wrapper": {
          "type": "panel",
          "size": [
            "100%",
            30
          ],
          "controls": [
            {
              "toggle_content@server_form.custom_toggle": {
                "$text_color": [
                  0.95,
                  0.95,
                  0.95
                ],
                "size": [
                  "100%",
                  "100%"
                ],
                "$option_tooltip_binding_type": "collection",
                "$option_tooltip_collection_name": "custom_form",
                "$option_tooltip_text_binding_name": "#custom_tooltip_text",
                "$option_tooltip_area": "inside_header_panel"
              }
            }
          ]
        }
      },
      {
        "toggle_spacer": {
          "type": "panel",
          "size": [
            "100%",
            10
          ]
        }
      }
    ]
  },
  "custom_slider": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "slider_wrapper": {
          "type": "panel",
          "size": [
            "100%",
            30
          ],
          "controls": [
            {
              "slider_content@server_form.custom_slider": {
                "$text_color": [
                  0.95,
                  0.95,
                  0.95
                ],
                "size": [
                  "100%",
                  "100%"
                ],
                "$option_tooltip_binding_type": "collection",
                "$option_tooltip_collection_name": "custom_form",
                "$option_tooltip_text_binding_name": "#custom_tooltip_text",
                "$option_tooltip_area": "inside_header_panel"
              }
            }
          ]
        }
      },
      {
        "slider_spacer": {
          "type": "panel",
          "size": [
            "100%",
            8
          ]
        }
      }
    ]
  },
  "custom_step_slider": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "step_slider_wrapper": {
          "type": "panel",
          "size": [
            "100%",
            30
          ],
          "controls": [
            {
              "step_slider_content@server_form.custom_step_slider": {
                "$text_color": [
                  0.95,
                  0.95,
                  0.95
                ],
                "size": [
                  "100%",
                  "100%"
                ],
                "$option_tooltip_binding_type": "collection",
                "$option_tooltip_collection_name": "custom_form",
                "$option_tooltip_text_binding_name": "#custom_tooltip_text",
                "$option_tooltip_area": "inside_header_panel"
              }
            }
          ]
        }
      },
      {
        "step_slider_spacer": {
          "type": "panel",
          "size": [
            "100%",
            8
          ]
        }
      }
    ]
  },
  "custom_dropdown": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "dropdown_top_spacer": {
          "type": "panel",
          "size": [
            "100%",
            4
          ]
        }
      },
      {
        "dropdown_wrapper": {
          "type": "panel",
          "size": [
            "100%",
            30
          ],
          "controls": [
            {
              "dropdown_content@server_form.custom_dropdown": {
                "$text_color": [
                  0.95,
                  0.95,
                  0.95
                ],
                "size": [
                  "100%",
                  "100%"
                ],
                "$option_tooltip_binding_type": "collection",
                "$option_tooltip_collection_name": "custom_form",
                "$option_tooltip_text_binding_name": "#custom_tooltip_text",
                "$option_tooltip_area": "inside_header_panel"
              }
            }
          ]
        }
      },
      {
        "dropdown_spacer": {
          "type": "panel",
          "size": [
            "100%",
            12
          ]
        }
      }
    ]
  },
  "custom_input": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "input_top_spacer": {
          "type": "panel",
          "size": [
            "100%",
            4
          ]
        }
      },
      {
        "input_wrapper": {
          "type": "panel",
          "size": [
            "100%",
            30
          ],
          "controls": [
            {
              "input_content@server_form.custom_input": {
                "size": [
                  "100%",
                  "100%"
                ],
                "$text_color": [
                  1.0,
                  1.0,
                  1.0
                ],
                "$option_tooltip_binding_type": "collection",
                "$option_tooltip_collection_name": "custom_form",
                "$option_tooltip_text_binding_name": "#custom_tooltip_text",
                "$option_tooltip_area": "inside_header_panel"
              }
            }
          ]
        }
      },
      {
        "input_spacer": {
          "type": "panel",
          "size": [
            "100%",
            10
          ]
        }
      }
    ]
  }
}